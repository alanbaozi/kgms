########################################
# LightRAG server
########################################
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE=KGMS LightRAG
WEBUI_DESCRIPTION=KGMS military knowledge graph RAG
SUMMARY_LANGUAGE=Chinese
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=209715200

# LightRAG API 默认不启用认证；服务器先靠安全组/防火墙限制访问。
# LIGHTRAG_API_KEY=
# WHITELIST_PATHS=/health,/api/*

########################################
# Document processing and multimodal
########################################
ENTITY_EXTRACTION_USE_JSON=true
# LightRAG v1.5+ loads entity type guidance and extraction examples from this profile.
# ENTITY_TYPES is deprecated in v1.5+ and should not be used for the new pipeline.
ENTITY_TYPE_PROMPT_FILE=military.yml
LIGHTRAG_PARSER=*:native-iteP,*:mineru-iteP,*:legacy-R

MINERU_API_MODE=official
MINERU_API_TOKEN=replace-with-mineru-api-token
MINERU_OFFICIAL_ENDPOINT=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_IS_OCR=false
MINERU_LANGUAGE=ch
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=true

VLM_PROCESS_ENABLE=true
VLM_LLM_BINDING=openai
VLM_LLM_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_LLM_BINDING_API_KEY=replace-with-dashscope-api-key
VLM_LLM_MODEL=qwen3.6-plus
VLM_MAX_ASYNC_LLM=4
VLM_LLM_TIMEOUT=240
VLM_MAX_IMAGE_BYTES=5242880

########################################
# LLM
########################################
LLM_BINDING=openai
LLM_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BINDING_API_KEY=replace-with-dashscope-api-key
LLM_MODEL=qwen3.6-plus
QUERY_LLM_MODEL=qwen3.6-plus-2026-04-02
KEYWORD_LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT=240
MAX_ASYNC=8
MAX_PARALLEL_INSERT=1
EXTRACT_MAX_ASYNC_LLM=8
EXTRACT_LLM_TIMEOUT=300
EMBEDDING_FUNC_MAX_ASYNC=4
EMBEDDING_BATCH_NUM=8

########################################
# Embedding
########################################
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BINDING_API_KEY=replace-with-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=true
EMBEDDING_USE_BASE64=false

########################################
# Rerank
########################################
RERANK_BINDING=aliyun
RERANK_MODEL=qwen3-rerank
RERANK_BINDING_HOST=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_BINDING_API_KEY=replace-with-dashscope-api-key
RERANK_BY_DEFAULT=true
MIN_RERANK_SCORE=0.0

########################################
# Storage selection
########################################
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DATABASE=rag
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_VECTOR_INDEX_TYPE=HNSW

REDIS_URI=redis://redis:6379
REDIS_MAX_CONNECTIONS=50

NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=lightrag
MILVUS_DEVICE=cpu
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE

MINIO_ACCESS_KEY_ID=replace-with-minio-access-key
MINIO_SECRET_ACCESS_KEY=replace-with-minio-secret-key

########################################
# Optional local admin ports
########################################
NEO4J_HTTP_HOST=127.0.0.1
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_HOST=127.0.0.1
NEO4J_BOLT_PORT=7687
MILVUS_GRPC_HOST=127.0.0.1
MILVUS_GRPC_PORT=19530
MILVUS_HTTP_HOST=127.0.0.1
MILVUS_HTTP_PORT=9091

########################################
# KGMS frontend public port
########################################
KGMS_WEB_HOST=0.0.0.0
KGMS_WEB_PORT=8080

########################################
# KGMS image build mirrors
########################################
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com
