########################################
# KGMS backend
########################################
KGMS_DATABASE_URL=sqlite:////app/data/kgms.db
KGMS_STORAGE_ROOT=/app/data/kgms
KGMS_ENV_PATH=/app/config/kgms.env
KGMS_MANAGED_LIGHTRAG_ROOT=/managed/lightrag-server

########################################
# LightRAG service managed by this Compose stack
########################################
KGMS_LIGHTRAG_BASE_URL=http://lightrag:9621
KGMS_LIGHTRAG_API_KEY=
KGMS_LIGHTRAG_TIMEOUT_SECONDS=180

# Enabling this allows KGMS to restart kgms-lightrag through Docker socket.
# Keep it false if you do not mount /var/run/docker.sock into kgms-backend.
KGMS_LIGHTRAG_RESTART_ENABLED=true
KGMS_LIGHTRAG_RESTART_STRATEGY=docker_socket
KGMS_LIGHTRAG_CONTAINER_NAME=kgms-lightrag
KGMS_DOCKER_SOCKET_PATH=/var/run/docker.sock
KGMS_DOCKER_COMPOSE_COMMAND=docker compose

########################################
# PageIndex
########################################
KGMS_PAGEINDEX_BASE_URL=https://api.pageindex.dev/v1
KGMS_PAGEINDEX_API_KEY=replace-with-pageindex-api-key
KGMS_PAGEINDEX_PROFILE=dev_v1
KGMS_PAGEINDEX_TIMEOUT_SECONDS=180

########################################
# Retrieval defaults
########################################
KGMS_DEFAULT_TOP_K=10
