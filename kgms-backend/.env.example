KGMS_DATABASE_URL=sqlite:///./data/kgms.db
KGMS_STORAGE_ROOT=./data/kgms
KGMS_ENV_PATH=./.env
KGMS_MANAGED_LIGHTRAG_ROOT=./mock/lightrag-server
KGMS_LIGHTRAG_RESTART_ENABLED=false
KGMS_LIGHTRAG_RESTART_STRATEGY=compose
KGMS_LIGHTRAG_CONTAINER_NAME=kgms-lightrag
KGMS_DOCKER_SOCKET_PATH=/var/run/docker.sock
KGMS_DOCKER_COMPOSE_COMMAND=docker compose
KGMS_LIGHTRAG_BASE_URL=https://lightrag.example
KGMS_LIGHTRAG_API_KEY=replace-with-lightrag-api-key
KGMS_LIGHTRAG_TIMEOUT_SECONDS=180
KGMS_PAGEINDEX_BASE_URL=https://api.pageindex.ai
KGMS_PAGEINDEX_API_KEY=replace-with-pageindex-api-key
KGMS_PAGEINDEX_PROFILE=official
KGMS_PAGEINDEX_TIMEOUT_SECONDS=180
KGMS_DEFAULT_TOP_K=10
